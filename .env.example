# Copy to .env and adjust for your environment.
# All variables are optional; defaults are in rag_proxy/config.py.
#
# Quick start:
#   1. cp .env.example .env
#   2. Set QDRANT_URL and QDRANT_COLLECTION (required for RAG)
#   3. Leave ENABLE_COGNITIVE_PIPELINE=false until legacy RAG works
#   4. python rag_proxy.py  —  point clients at http://<host>:<PROXY_PORT>/v1
# See docs/getting-started.md (verify) and docs/cognitive-pipeline.md (rollout).
#
# Default ports (overridable): rag-proxy 8088, llama-swap 8080,
# nomic-embed (llama-server --embedding) 8089 — usually 127.0.0.1 only.

# --- Core proxy (existing) ---
LLAMA_SWAP_URL=http://127.0.0.1:8080
# llama.cpp llama-server: nomic-embed-text only, hot-loaded (see nomic-embed.service)
# Requires CUDA build with -ngl 99 (~1 GiB VRAM). Copy nomic-embed.env.example to /opt/ai/config/nomic-embed.env
EMBED_URL=http://127.0.0.1:8089
QDRANT_URL=http://192.168.1.10:6333
QDRANT_COLLECTION=nomad_knowledge_base
TOP_K=5
SIMILARITY_THRESHOLD=0.65
PROXY_HOST=0.0.0.0
# Use another PROXY_PORT (e.g. 8087) for a side-by-side second instance.
PROXY_PORT=8088
LOG_LEVEL=INFO
EMBED_MAX_CHARS=2000
EMBED_RETRIES=2

# Upstream pool (all clients hit proxy; llama-swap stays on localhost/firewall)
UPSTREAM_TIMEOUT_SEC=600
UPSTREAM_MAX_CONNECTIONS=50
# 0 = close socket after each one-shot poll (GET /v1/models, /metrics, etc.)
UPSTREAM_MAX_KEEPALIVE=0
UPSTREAM_KEEPALIVE_EXPIRY_SEC=15
UPSTREAM_IDLE_SWEEP_SEC=30
# Close upstream SSE streams with no bytes relayed for this long (not total stream age).
UPSTREAM_STREAM_ABANDON_SEC=120

# --- Cognitive pipeline (default off = legacy always-retrieve behavior) ---
ENABLE_COGNITIVE_PIPELINE=false
ENABLE_TIER0_HEURISTICS=false
ENABLE_INTENT_ROUTER=false
ENABLE_RETRIEVAL_GATING=false
GATING_LOG_ONLY=false
ENABLE_QUERY_REWRITE=false
ENABLE_QUERY_REWRITE_LLM=false
ENABLE_HYBRID_RETRIEVAL=false
ENABLE_RERANKER=false
ENABLE_SEMANTIC_DEDUPE=false
ENABLE_GRAPH_LOOKUP=false
ENABLE_MODEL_ROUTING=false
MODEL_ROUTING_MODE=suggest
ENABLE_TOOLS=false
ENABLE_ROLLING_MEMORY=false
ENABLE_EMBED_CACHE=false
ENABLE_TOKENIZER_ESTIMATE=false

# --- Budgets ---
COGNITIVE_LATENCY_BUDGET_MS=800
STAGE_BUDGET_ROUTING_MS=0
STAGE_BUDGET_REWRITE_MS=20
STAGE_BUDGET_RETRIEVE_MS=50
STAGE_BUDGET_GRAPH_MS=100
RETRIEVAL_CANDIDATE_K=20
CONTEXT_BUDGET_RATIO=0.25
CONTEXT_FALLBACK_CHARS=8000
DEFAULT_COMPLETION_RESERVE=1024
TIER0_MAX_CHARS=80

# --- Intent ---
INTENT_MODEL=
INTENT_CONFIDENCE_THRESHOLD=0.55
INTENT_TIMEOUT_MS=150

# --- Hybrid / rerank ---
HYBRID_DENSE_WEIGHT=0.7
SPARSE_INDEX_URL=
RECENCY_WEIGHT=0.1
RERANKER_URL=http://127.0.0.1:8095
RERANK_TOP_K=5
RERANK_TIMEOUT_MS=200

# --- Graph / tools / memory ---
GRAPH_DB_PATH=/var/lib/rag_proxy/graph.sqlite
GRAPH_MAX_DEPTH=2

# --- MemGraphRAG (arxiv 2606.00610) ---
ENABLE_MEMGRAPHRAG=false
MEMGRAPHRAG_DB_PATH=/var/lib/rag_proxy/memgraphrag.sqlite
MEMGRAPHRAG_FACT_TOP_K=20
MEMGRAPHRAG_PPR_DAMPING=0.85
MEMGRAPHRAG_PPR_ITERATIONS=20
MEMGRAPHRAG_PASSAGE_NODE_WEIGHT=0.5
STAGE_BUDGET_MEMGRAPHRAG_MS=200

TOOL_ALLOWED_ROOTS=/var/lib/rag_proxy/files
TOOL_TIMEOUT_SEC=5
TOOL_BUDGET_MS=300
TOOL_MAX_OUTPUT_CHARS=4000
MEMORY_DB_PATH=/var/lib/rag_proxy/memory.sqlite
MEMORY_TTL_HOURS=72
MEMORY_REFRESH_TURNS=8

# --- Model registry / routing ---
MODEL_REGISTRY_TTL_SEC=300
MODEL_REGISTRY_CONFIG_PATH=
MODEL_CAPABILITIES_JSON=
MODEL_ROUTES_JSON=

# --- Transcript capture (fine-tuning + RAG improvement) ---
ENABLE_TRANSCRIPT_CAPTURE=false
FINETUNE_LOG_PATH=/var/lib/rag_proxy/capture/finetune.jsonl
RAG_IMPROVEMENT_LOG_PATH=/var/lib/rag_proxy/capture/rag_improvement.jsonl
TRANSCRIPT_STRIP_PROXY_ARTEFACTS=true
TRANSCRIPT_HEADER_OPT_IN=false
TRANSCRIPT_SAMPLE_RATE=1.0
TRANSCRIPT_HIT_PREVIEW_CHARS=300
ENABLE_RAG_CORPUS_AUTO_INGEST=false
RAG_CORPUS_COLLECTION=nomad_conversation_derived
RAG_CORPUS_MIN_ANSWER_CHARS=100
RAG_CORPUS_REQUIRE_CHUNKS=false

# --- Observability ---
ENABLE_JSON_LOGS=false
ENABLE_REQUEST_TRACE=true
# ENABLE_METRICS=true exposes GET /metrics on the proxy port (not a separate listener)
ENABLE_METRICS=false
# Legacy: METRICS_PORT>0 also enables metrics when ENABLE_METRICS is unset/false
METRICS_PORT=0

# --- RAG admin UI + ingest worker (rag_admin/) — optional, separate from proxy ---
# ADMIN_HOST=127.0.0.1
# ADMIN_PORT=8087
# ADMIN_DB_PATH=/opt/ai/rag/admin.sqlite
# ZIM_DIR=/opt/ai/rag/zim
# UPLOAD_DIR=/opt/ai/rag/uploads
# ADMIN_SESSION_SECRET=change-me-in-production
# ADMIN_PASSWORD=changeme
# ADMIN_ALLOW_INSECURE_DEFAULTS=true
# INGEST_BATCH_SIZE=64
# INGEST_EMBED_CONCURRENCY=4
# INGEST_MAX_ARTICLES=0
# INGEST_SPARSE_REINDEX=idle
# INGEST_STALL_MINUTES=15
# RAG_PROXY_URL=http://127.0.0.1:8081
