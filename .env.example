# Copy to .env and adjust for your environment.
# All variables are optional; defaults are in rag_proxy/config.py.
#
# Quick start:
#   1. cp .env.example .env
#   2. Set QDRANT_URL and QDRANT_COLLECTION (required for RAG)
#   3. Leave ENABLE_COGNITIVE_PIPELINE=false until legacy RAG works
#   4. python rag_proxy.py  —  point clients at http://<host>:<PROXY_PORT>/v1
# See docs/getting-started.md (verify) and docs/cognitive-pipeline.md (rollout).
#
# Default ports (overridable): rag-proxy 8088, upstream chat API 8080 (llama-swap typical),
# nomic-embed (llama-server --embedding) 8089 — usually 127.0.0.1 only.

# --- Core proxy (existing) ---
# Upstream OpenAI-compatible chat API (llama-swap, llama-server, vLLM, OpenRouter, OpenAI, …)
LLAMA_SWAP_URL=http://127.0.0.1:8080
# llama.cpp llama-server: nomic-embed-text only, hot-loaded (see nomic-embed.service)
# Requires CUDA build with -ngl 99 (~1 GiB VRAM). Copy nomic-embed.env.example to /opt/ai/config/nomic-embed.env
EMBED_URL=http://127.0.0.1:8089
QDRANT_URL=http://192.168.1.36:6333
QDRANT_COLLECTION=nomad_knowledge_base
# Ingest upsert resilience (ingest/qdrant_writer.py; raise timeout on slow hosts)
# QDRANT_UPSERT_TIMEOUT_SEC=180
# QDRANT_UPSERT_RETRIES=4
# QDRANT_UPSERT_BACKOFF_SEC=2
TOP_K=5
SIMILARITY_THRESHOLD=0.65
PROXY_HOST=0.0.0.0
# Use another PROXY_PORT (e.g. 8087) for a side-by-side second instance.
PROXY_PORT=8088
LOG_LEVEL=INFO
EMBED_MAX_CHARS=2000
EMBED_RETRIES=2

# Upstream pool (all clients hit proxy; upstream may stay on localhost/firewall)
UPSTREAM_TIMEOUT_SEC=600
UPSTREAM_MAX_CONNECTIONS=50
# 0 = close socket after each one-shot poll (GET /v1/models, /metrics, etc.)
UPSTREAM_MAX_KEEPALIVE=0
UPSTREAM_KEEPALIVE_EXPIRY_SEC=15
UPSTREAM_IDLE_SWEEP_SEC=30
# Close upstream SSE streams with no bytes relayed for this long (not total stream age).
UPSTREAM_STREAM_ABANDON_SEC=120

# Optional shared-secret gate when proxy is reachable on LAN/Tailscale (PROXY_HOST=0.0.0.0).
# When set, clients must send header X-Internal-Token with this value on every proxy request
# and on GET /metrics. Leave empty (default) for no change.
PROXY_INTERNAL_TOKEN=

# --- Cognitive pipeline (default off = legacy always-retrieve behavior) ---
ENABLE_COGNITIVE_PIPELINE=false
ENABLE_TIER0_HEURISTICS=false
ENABLE_INTENT_ROUTER=false
ENABLE_RETRIEVAL_GATING=false
GATING_LOG_ONLY=false
ENABLE_QUERY_REWRITE=false
ENABLE_QUERY_REWRITE_LLM=false
ENABLE_HYBRID_RETRIEVAL=false
ENABLE_RERANKER=false
ENABLE_SEMANTIC_DEDUPE=false
ENABLE_GRAPH_LOOKUP=false
ENABLE_MODEL_ROUTING=false
MODEL_ROUTING_MODE=suggest
ENABLE_TOOLS=false
ENABLE_ROLLING_MEMORY=false
ENABLE_EMBED_CACHE=false
ENABLE_TOKENIZER_ESTIMATE=false

# --- Budgets ---
COGNITIVE_LATENCY_BUDGET_MS=800
STAGE_BUDGET_ROUTING_MS=0
STAGE_BUDGET_REWRITE_MS=20
STAGE_BUDGET_RETRIEVE_MS=50
STAGE_BUDGET_GRAPH_MS=100
RETRIEVAL_CANDIDATE_K=20
CONTEXT_BUDGET_RATIO=0.25
CONTEXT_FALLBACK_CHARS=8000
DEFAULT_COMPLETION_RESERVE=1024
TIER0_MAX_CHARS=80

# --- Intent ---
# Model id, or "auto" to reuse the model llama-swap currently has loaded (via /running).
INTENT_MODEL=
# Optional dedicated endpoint for intent/rewrite calls; empty falls back to LLAMA_SWAP_URL.
INTENT_MODEL_URL=
# Cache window for "auto" resolution; keep short so it tracks model swaps.
INTENT_MODEL_AUTO_TTL_SEC=10
INTENT_CONFIDENCE_THRESHOLD=0.55
INTENT_TIMEOUT_MS=150

# --- Hybrid / rerank ---
HYBRID_DENSE_WEIGHT=0.7
SPARSE_INDEX_URL=
RECENCY_WEIGHT=0.1
RERANKER_URL=http://127.0.0.1:8095
RERANK_TOP_K=5
RERANK_TIMEOUT_MS=200

# --- Graph / tools / memory ---
GRAPH_DB_PATH=/var/lib/rag_proxy/graph.sqlite
GRAPH_MAX_DEPTH=2

# --- MemGraphRAG (arxiv 2606.00610) ---
ENABLE_MEMGRAPHRAG=false
MEMGRAPHRAG_DB_PATH=/var/lib/rag_proxy/memgraphrag.sqlite
MEMGRAPHRAG_FACT_TOP_K=20
MEMGRAPHRAG_PPR_DAMPING=0.85
MEMGRAPHRAG_PPR_ITERATIONS=20
MEMGRAPHRAG_PASSAGE_NODE_WEIGHT=0.5
STAGE_BUDGET_MEMGRAPHRAG_MS=200
STAGE_EXEC_TIMEOUT_MS=30000

TOOL_ALLOWED_ROOTS=/var/lib/rag_proxy/files
TOOL_TIMEOUT_SEC=5
TOOL_BUDGET_MS=300
TOOL_MAX_OUTPUT_CHARS=4000
MEMORY_DB_PATH=/var/lib/rag_proxy/memory.sqlite
MEMORY_TTL_HOURS=72
MEMORY_REFRESH_TURNS=8

# MemGraphRAG offline index build (scripts/build_memgraphrag_index.py; also in rag-admin Settings)
# Point at remote qwen when local llama-swap GPU is busy with ingest:
# MEMGRAPH_BUILD_LLM_URL=http://192.168.1.202:8081/v1
# MEMGRAPH_BUILD_LLM_MODEL=qwen3.5-9b-turbo
MEMGRAPH_BUILD_LLM_URL=http://127.0.0.1:8080/v1
MEMGRAPH_BUILD_LLM_MODEL=qwen3.5-9b-turbo
MEMGRAPH_BUILD_MAX_CHUNKS=1000
MEMGRAPH_BUILD_CONCURRENCY=3
# MEMGRAPH_BUILD_EMBED_URL=http://127.0.0.1:18089
MEMGRAPH_BUILD_SKIP_RELATIONS=false

# --- Model registry / routing ---
MODEL_REGISTRY_TTL_SEC=300
MODEL_CAPABILITIES_JSON=
MODEL_ROUTES_JSON=

# --- Transcript capture (fine-tuning + RAG improvement) ---
ENABLE_TRANSCRIPT_CAPTURE=false
FINETUNE_LOG_PATH=/var/lib/rag_proxy/capture/finetune.jsonl
RAG_IMPROVEMENT_LOG_PATH=/var/lib/rag_proxy/capture/rag_improvement.jsonl
TRANSCRIPT_STRIP_PROXY_ARTEFACTS=true
TRANSCRIPT_HEADER_OPT_IN=false
TRANSCRIPT_SAMPLE_RATE=1.0
TRANSCRIPT_HIT_PREVIEW_CHARS=300
ENABLE_RAG_CORPUS_AUTO_INGEST=false
RAG_CORPUS_COLLECTION=nomad_conversation_derived
RAG_CORPUS_MIN_ANSWER_CHARS=100
RAG_CORPUS_REQUIRE_CHUNKS=false

# --- Observability ---
ENABLE_JSON_LOGS=false
ENABLE_REQUEST_TRACE=true
# ENABLE_METRICS=true exposes GET /metrics on the proxy port (not a separate listener)
ENABLE_METRICS=false

# --- RAG admin UI + ingest worker (rag_admin/) — optional, separate from proxy ---
# ADMIN_HOST=127.0.0.1
# ADMIN_PORT=8087
# ADMIN_DB_PATH=/opt/ai/rag/admin.sqlite
# ZIM_DIR=/opt/ai/rag/zim
# UPLOAD_DIR=/opt/ai/rag/uploads
# ADMIN_SESSION_SECRET=change-me-in-production
# ADMIN_PASSWORD=changeme
# ADMIN_SESSION_TTL_SECONDS=604800
# ADMIN_LOGIN_MAX_ATTEMPTS=5
# ADMIN_LOGIN_LOCKOUT_MINUTES=15
# ADMIN_ALLOW_INSECURE_DEFAULTS=true
# INGEST_BATCH_SIZE=64
# INGEST_EMBED_CONCURRENCY=4
# INGEST_FILE_CONCURRENCY=
# INGEST_CHUNK_CONCURRENCY=
# INGEST_MAX_ARTICLES=0
# INGEST_SPARSE_REINDEX=idle
# INGEST_STALL_MINUTES=15
# Hide Indexed rows on /jobs after this many minutes (0 = show all). Override with ?show_indexed=1
# INGEST_HIDE_INDEXED_MINUTES=60
# Capacity planner caps (scripts/scale_ingest_capacity.py; see docs/ingest-capacity-planning.md)
# INGEST_CAPACITY_RAM_RESERVE_MIB=4096
# INGEST_CAPACITY_RAM_PER_FILE_MIB=2048
# INGEST_CAPACITY_SEMANTIC_RAM_FLOOR_MIB=8192
# INGEST_CAPACITY_SEMANTIC_CPU_FLOOR=4
# INGEST_CAPACITY_CHUNK_CPU_SHARE=2
# INGEST_CAPACITY_MAX_FILE_CONCURRENCY=8
# INGEST_CAPACITY_MIN_DISK_MBPS=100
# INGEST_CAPACITY_SLOW_DISK_FILE_CAP=2
# INGEST_CAPACITY_SPARSE_REINDEX=off
# Qdrant-aware ingest caps (ingest/capacity_planner.py)
# INGEST_CAPACITY_QDRANT_RAM_BUDGET_MIB=8192
# INGEST_CAPACITY_QDRANT_LARGE_COLLECTION_POINTS=500000
# INGEST_CAPACITY_QDRANT_HUGE_COLLECTION_POINTS=2000000
# Sidecar on-demand lifecycle (ingest/sidecar_lifecycle.py; rag-admin guard)
# SIDECAR_ON_DEMAND=true
# SIDECAR_STARTUP_TIMEOUT_SEC=900
# SIDECAR_RERANK_STARTUP_TIMEOUT_SEC=180
# SIDECAR_LIFECYCLE_POLL_SEC=20
# SPARSE_SIDECAR_UNIT=sparse-sidecar.service
# RERANK_SIDECAR_UNIT=rerank-sidecar.service
# Chonkie chunking (ingest/chunking_strategy.py picks strategy per file; see docs/ingest-and-admin.md)
INGEST_CHUNK_SIZE_TOKENS=512
INGEST_CHUNK_OVERLAP_TOKENS=64
INGEST_CHUNK_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
INGEST_CHUNK_SEMANTIC=true
INGEST_CHUNK_SEMANTIC_MODEL=minishlab/potion-base-32M
INGEST_CHUNK_MIN_TOKENS=100
# RAG_PROXY_URL=http://127.0.0.1:8081
# RAG_ADMIN_ENV_FILE=/opt/ai/config/rag-admin.env
# RAG_PROXY_ENV_FILE=/opt/ai/config/rag-proxy.env
# RAG_REPO_ROOT=/opt/ai/repo/rag_proxy
# RAG_ADMIN_JOB_LOG_DIR=/var/lib/rag_proxy/admin_jobs
# RAG_PROXY_RESTART_CMD=systemctl restart rag-proxy
# RAG_ADMIN_RESTART_CMD=systemctl restart rag-admin
# RAG_EMBED_POOL_RESTART_CMD=systemctl restart nomic-embed-scale
# EMBED_ON_DEMAND=true
# NOMIC_QUERY_EMBED_PORT=8089
# EMBED_IDLE_STOP_SEC=180
# EMBED_IDLE_PAUSED_SEC=30
# EMBED_IDLE_POLL_SEC=15
# EMBED_STARTUP_TIMEOUT_SEC=120
# EMBED_ACTIVITY_STAMP_PATH=/var/lib/rag_proxy/embed_last_activity
# PROXY_GRACEFUL_SHUTDOWN_SEC=15
# ADMIN_GRACEFUL_SHUTDOWN_SEC=15
