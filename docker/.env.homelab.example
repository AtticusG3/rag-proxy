# Homelab cognitive flags (copy needed lines into docker/.env).
# Use with: docker compose --profile qdrant --profile cognitive up -d --build

ENABLE_COGNITIVE_PIPELINE=true
ENABLE_TIER0_HEURISTICS=true
ENABLE_RETRIEVAL_GATING=true
GATING_LOG_ONLY=false
ENABLE_REQUEST_TRACE=true
ENABLE_JSON_LOGS=false

# Tier 2 optional subsystems (require --profile cognitive sidecars)
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_RERANKER=true
ENABLE_SEMANTIC_DEDUPE=false
ENABLE_QUERY_REWRITE=false

# Tier 3 (SQLite on rag_proxy_state volume; no extra containers)
ENABLE_GRAPH_LOOKUP=false
ENABLE_TOOLS=false
ENABLE_ROLLING_MEMORY=false

# Intent via llama-swap (optional; set INTENT_MODEL in docker/config.yaml)
ENABLE_INTENT_ROUTER=false
INTENT_MODEL=
INTENT_CONFIDENCE_THRESHOLD=0.55

# Sidecar tuning
RERANK_TOP_K=5
RERANK_TIMEOUT_MS=500
HYBRID_DENSE_WEIGHT=0.7
SPARSE_REFRESH_SEC=3600
COGNITIVE_LATENCY_BUDGET_MS=1200
