# Copy to docker/.env and adjust. Used by docker compose (rag-proxy service).

# Host directory mounted at /models in llama-swap and nomic-embed (GGUF files).
MODELS_DIR=/path/to/models

# Qdrant (required for RAG).
# Bundled Qdrant (--profile qdrant): QDRANT_URL=http://qdrant:6333
# External Qdrant: QDRANT_URL=http://192.168.1.10:6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=nomad_knowledge_base

# Published host ports (container ports stay fixed internally)
RAG_PROXY_HOST_PORT=8088
LLAMA_SWAP_HOST_PORT=8080
RERANKER_HOST_PORT=8095
SPARSE_INDEX_HOST_PORT=8096
QDRANT_HOST_PORT=6333

# Images (defaults match docker-compose.yml)
LLAMA_SWAP_IMAGE=ghcr.io/mostlygeek/llama-swap:cuda
NOMIC_EMBED_IMAGE=ghcr.io/mostlygeek/llama-swap:cuda
RAG_PROXY_IMAGE=rag-proxy:local
RERANKER_IMAGE=rag-reranker:local
SPARSE_INDEX_IMAGE=rag-sparse-index:local

# Path inside MODELS_DIR mount (must exist on host)
NOMIC_EMBED_MODEL=/models/nomic-embed/nomic-embed-text-v1.5.Q8_0.gguf

# GPU visibility for llama-swap:cuda
NVIDIA_VISIBLE_DEVICES=all

# --- RAG tuning (legacy path; defaults from rag_proxy/config.py) ---
TOP_K=5
SIMILARITY_THRESHOLD=0.65
EMBED_MAX_CHARS=2000
LOG_LEVEL=INFO
ENABLE_COGNITIVE_PIPELINE=false

# Cognitive state DBs (mounted volume rag_proxy_state -> /var/lib/rag_proxy)
GRAPH_DB_PATH=/var/lib/rag_proxy/graph.sqlite
MEMORY_DB_PATH=/var/lib/rag_proxy/memory.sqlite

# --- Full homelab stack ---
# Copy docker/.env.homelab.example fields into docker/.env when using:
#   docker compose --profile qdrant --profile cognitive up -d --build
# Sidecar URLs (RERANKER_URL, SPARSE_INDEX_URL) are set in docker-compose.yml.

RERANK_MODEL=BAAI/bge-reranker-base
SPARSE_REFRESH_SEC=3600
