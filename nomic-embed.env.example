# Copy to /opt/ai/config/nomic-embed.env (or nomad equivalent) and adjust paths.
# Loaded by nomic-embed.service and nomic-embed@.service

LLAMA_SERVER_BIN=/opt/ai/bin/llama-server
NOMIC_EMBED_MODEL=/opt/ai/models/embed/nomic-embed-text-v1.5.Q8_0.gguf

# Full GPU offload (nomic-embed is ~300MB; fits any GPU)
NOMIC_GPU_LAYERS=99

# Pin embedding to a specific GPU. Loaded by both nomic-embed.service (query :8089)
# and nomic-embed@.service (bulk pool), so this moves ALL embedding onto one card and
# leaves the others free for LLM inference (e.g. embed on a small GPU, keep a big one
# for the LLM).
#
# The index is the CUDA runtime order, which can DIFFER from nvidia-smi. Check the map:
#   /opt/ai/bin/llama-server --list-devices
# then set this to the CUDAn index of the target card. NOMIC_POOL_GPU_INDEX in
# nomic-embed-scale.env uses the nvidia-smi index instead (also may differ) — point
# both at the same physical card.
#
# The binary must be compiled for that GPU's CUDA architecture
# (CMAKE_CUDA_ARCHITECTURES). A V100-only build (sm_70) aborts with a CUDA error on an
# Ada card (sm_89) — build with e.g. -DCMAKE_CUDA_ARCHITECTURES="70;89".
# CUDA_VISIBLE_DEVICES=0

# Query embed (:8089) — single slot, low parallel
NOMIC_CONTEXT=8096
NOMIC_PARALLEL=4

# Bulk pool (nomic-embed@PORT) — override in nomic-embed-scale.env
# NOMIC_POOL_PARALLEL=16
