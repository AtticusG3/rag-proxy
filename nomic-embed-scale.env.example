# Copy to /opt/ai/config/nomic-embed-scale.env
# Used by nomic-embed@.service and scripts/scale_nomic_embed_pool.py

# Pool sizing (see ingest/embed_pool.py)
NOMIC_POOL_VRAM_PER_INSTANCE_MIB=1024
# embed_pool.py default is 2048 if unset; 6144 is a conservative homelab override
NOMIC_POOL_VRAM_RESERVE_MIB=6144
NOMIC_POOL_PORT_BASE=18089
NOMIC_POOL_MAX_INSTANCES=8
NOMIC_POOL_MIN_INSTANCES=1
NOMIC_POOL_PARALLEL_PER_INSTANCE=16
# Physical GPU the capacity planner probes (nvidia-smi --id). To move embedding to
# another card, set CUDA_VISIBLE_DEVICES in nomic-embed.env and keep this equal to it
# so the planner sizes the pool against the GPU the instances actually run on.
NOMIC_POOL_GPU_INDEX=0

# Bulk ingest: --parallel passed to llama-server in nomic-embed@.service.
# The capacity planner writes this into nomic-embed-pool.env so systemd and
# INGEST_EMBED_CONCURRENCY math stay aligned; keep it equal to PARALLEL_PER_INSTANCE.
NOMIC_POOL_PARALLEL=16
